<Window x:Class="GoMuot.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chào mừng đến GoMuot"
        Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Page Container -->
        <TabControl x:Name="PageTabs"
                    BorderThickness="0"
                    Background="Transparent"
                    Padding="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- Page 1: Welcome -->
            <TabItem>
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="GoMuot"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Gõ Tiếng Việt Nhanh"
                                   FontSize="16"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>

                        <TextBlock TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,40,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}">
                            <Run Text="Bộ gõ tiếng Việt hiện đại, nhẹ và nhanh."/>
                            <LineBreak/>
                            <LineBreak/>
                            <Run Text="Cài đặt xong - Dùng ngay" FontWeight="SemiBold"/>
                            <LineBreak/>
                            <Run Text="Không quảng cáo - Không theo dõi - Miễn phí"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="1"
                            Content="Bắt đầu"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center"
                            Width="160"
                            Click="NextPage_Click"/>
                </Grid>
            </TabItem>

            <!-- Page 2: Simple Telex -->
            <TabItem>
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Simple Telex"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Bản Windows này dùng một kiểu gõ mặc định, gọn và dễ quen."
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <Border BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Simple Telex"
                                           FontWeight="SemiBold"
                                           FontSize="15"/>
                                <TextBlock Text="dd → đ   aw → ă   aa → â   ow → ơ   uw → ư"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           FontSize="13"/>
                                <TextBlock Text="Khác với Telex thường, phím w đứng riêng sẽ giữ nguyên là w."
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F3F4F6"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,12,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}">
                                <Run Text="Mẹo: " FontWeight="SemiBold"/>
                                <Run Text="Dùng Win + Space để bật hoặc tắt nhanh bộ gõ, giống thói quen đổi input trên Windows."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Quay lại"
                                Padding="16,8"
                                Margin="0,0,12,0"
                                Click="PrevPage_Click"/>
                        <Button Content="Tiếp theo"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                Click="NextPage_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Page 3: Done -->
            <TabItem>
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="Sẵn sàng!"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,24,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}">
                            <Run Text="GoMuot đang chạy trong khay hệ thống (system tray)."/>
                            <LineBreak/>
                            <LineBreak/>
                            <Run Text="Nhấp chuột phải vào biểu tượng 'V' để:" FontWeight="SemiBold"/>
                            <LineBreak/>
                            <Run Text="• Bật/tắt bộ gõ"/>
                            <LineBreak/>
                            <Run Text="• Mở nhanh thông tin và liên kết góp ý"/>
                        </TextBlock>

                        <Border Background="#F3F4F6"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,24,0,0">
                            <TextBlock TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}">
                                <Run Text="Mẹo: " FontWeight="SemiBold"/>
                                <Run Text="Nhấp đúp vào biểu tượng hoặc bấm Win + Space để nhanh chóng bật/tắt bộ gõ."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="1"
                            Content="Bắt đầu gõ tiếng Việt"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center"
                            Width="200"
                            Click="Finish_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Page Indicator -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20">
            <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="4"/>
            <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#E5E7EB" Margin="4"/>
            <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#E5E7EB" Margin="4"/>
        </StackPanel>
    </Grid>
</Window>
